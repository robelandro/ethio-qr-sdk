    "ips-et",
    "p2m",
    "qr-code",
    "interoperable"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robelandro/ethio-qr-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/robelandro/ethio-qr-sdk/issues"
  },
  "homepage": "https://github.com/robelandro/ethio-qr-sdk#readme",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  }
}
